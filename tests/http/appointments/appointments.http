@baseUrl = http://localhost:5199
@tenantSlug = demo

### ✅ Book appointment (201)
POST {{baseUrl}}/api/v1/appointments
Content-Type: application/json
X-Tenant: {{tenantSlug}}

{
  "patientId": "00000000-0000-0000-0000-000000000001",
  "providerId": "00000000-0000-0000-0000-000000000002",
  "appointmentTypeId": "00000000-0000-0000-0000-000000000003",
  "startAt": "2026-04-01T09:00:00Z",
  "endAt": "2026-04-01T10:00:00Z",
  "chiefComplaint": "Routine checkup",
  "notes": null,
  "operatoryId": null,
  "isNewPatient": false,
  "source": "Staff"
}

###

### ✅ List appointments (200)
GET {{baseUrl}}/api/v1/appointments
X-Tenant: {{tenantSlug}}

###

### ✅ Filter appointments by date range
GET {{baseUrl}}/api/v1/appointments?dateFrom=2026-04-01&dateTo=2026-04-30&page=1&pageSize=50
X-Tenant: {{tenantSlug}}

###

### ✅ Get appointment by ID (200) — replace {id}
GET {{baseUrl}}/api/v1/appointments/00000000-0000-0000-0000-000000000000
X-Tenant: {{tenantSlug}}

###

### ❌ Appointment not found (404)
GET {{baseUrl}}/api/v1/appointments/ffffffff-ffff-ffff-ffff-ffffffffffff
X-Tenant: {{tenantSlug}}

###

### ❌ Unauthorized (401)
GET {{baseUrl}}/api/v1/appointments

###

### ❌ Validation error - end before start (400)
POST {{baseUrl}}/api/v1/appointments
Content-Type: application/json
X-Tenant: {{tenantSlug}}

{
  "patientId": "00000000-0000-0000-0000-000000000001",
  "providerId": "00000000-0000-0000-0000-000000000002",
  "appointmentTypeId": "00000000-0000-0000-0000-000000000003",
  "startAt": "2026-04-01T10:00:00Z",
  "endAt": "2026-04-01T09:00:00Z",
  "isNewPatient": false,
  "source": "Staff"
}

###

### ✅ Cancel appointment — replace {id}
POST {{baseUrl}}/api/v1/appointments/00000000-0000-0000-0000-000000000000/cancel
Content-Type: application/json
X-Tenant: {{tenantSlug}}

{
  "reason": "Patient requested cancellation"
}

###

### ✅ Confirm appointment — replace {id}
PATCH {{baseUrl}}/api/v1/appointments/00000000-0000-0000-0000-000000000000/status
Content-Type: application/json
X-Tenant: {{tenantSlug}}

{
  "status": "Confirmed"
}

###

### ✅ Reschedule appointment — replace {id}
PUT {{baseUrl}}/api/v1/appointments/00000000-0000-0000-0000-000000000000/reschedule
Content-Type: application/json
X-Tenant: {{tenantSlug}}

{
  "newStartAt": "2026-04-02T10:00:00Z",
  "newEndAt": "2026-04-02T11:00:00Z"
}

